# Python Caches & Compiled Files
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environments (venv)
venv/
.venv/
# Conda environments should ideally live outside the project directory.

# IDE and OS specific files
.vscode/
.idea/
.DS_Store

# Jupyter Notebook Checkpoints
.ipynb_checkpoints/
