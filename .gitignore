.coverage

# Data, Models, and Results - Runtime generated, often large
data/*
!data/web/
!data/web/**
models/
results/

# Build artifacts and Packaging
*.egg-info/
build/
dist/

# Logs and Temporary Files
*.log
*~
*.tmp

# Environment variables
.env
